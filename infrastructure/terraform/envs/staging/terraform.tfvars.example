aws_region   = "ap-south-1"
project_name = "spendrax"

# Leave empty to use the default prefix: spendrax-staging.
resource_name_prefix = ""

vpc_cidr             = "10.20.0.0/16"
public_subnet_cidrs  = ["10.20.1.0/24", "10.20.2.0/24"]
private_subnet_cidrs = ["10.20.10.0/24", "10.20.11.0/24"]

instance_type    = "t3.small"
key_pair_name    = "spendrax-key"
allowed_ssh_cidr = "YOUR_IP_ADDRESS/32"
domain_name      = ""

documentdb_username                = "spendrax_admin"
documentdb_password                = "YourSecurePassword123!"
documentdb_instance_class          = "db.t3.medium"
documentdb_backup_retention_period = 7
documentdb_skip_final_snapshot     = true

jwt_secret_key = "your-super-secret-jwt-key-change-this"
openai_api_key = ""

artifact_retention_days = 30

enable_alb_deletion_protection = false
