aws_region   = "ap-south-1"
project_name = "spendrax"

# Leave empty to preserve the legacy production prefix: spendrax.
# Set "spendrax-prod" only for a brand-new production stack.
resource_name_prefix = ""

vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]

domain_name = ""

documentdb_username                = "spendrax_admin"
documentdb_password                = "YourSecurePassword123!"
documentdb_instance_class          = "db.t3.medium"
documentdb_backup_retention_period = 7
documentdb_skip_final_snapshot     = true

jwt_secret_key = "your-super-secret-jwt-key-change-this"
openai_api_key = ""

frontend_image_tag     = "bootstrap"
backend_image_tag      = "bootstrap"
frontend_desired_count = 0
backend_desired_count  = 0
frontend_task_cpu      = 256
frontend_task_memory   = 512
backend_task_cpu       = 512
backend_task_memory    = 1024
log_retention_days     = 14
force_delete_ecr_repositories = true

enable_alb_deletion_protection = false
