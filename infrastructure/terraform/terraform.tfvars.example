# AWS Configuration
aws_region   = "ap-south-1"
environment  = "prod"
project_name = "spendrax"

# EC2 Configuration
instance_type    = "t3.small"      # 2 vCPU, 2GB RAM (~$15/month)
key_pair_name    = "spendrax-key"  # Create this in AWS Console first

# Security - IMPORTANT: Restrict SSH to your IP!
allowed_ssh_cidr = "YOUR_IP_ADDRESS/32"  # e.g., "203.0.113.50/32"

# Domain (optional - leave empty if using IP only)
# domain_name = ""  # Legacy/custom-domain path only. Not used in the current ALB URL setup.

# DocumentDB Configuration
documentdb_username       = "spendrax_admin"
documentdb_password       = "YourSecurePassword123!"  # Min 8 characters
documentdb_instance_class = "db.t3.medium"            # Smallest available (~$56/month)

# Secrets - Use environment variables or AWS Secrets Manager in production
# DO NOT commit actual values!
jwt_secret_key = "your-super-secret-jwt-key-change-this"
openai_api_key = "sk-your-openai-api-key"
